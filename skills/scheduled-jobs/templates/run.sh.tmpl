#!/bin/bash
# scheduled-jobs wrapper — job: @JOB_NAME@ — generated by scheduled-jobs
# Contract: detect -> render -> lint -> launch -> record -> diff -> notify.
# Every attempt (including no-ops and failures) appends one line to runs.jsonl.
set -euo pipefail

JOB_NAME="@JOB_NAME@"
JOB_DIR="$HOME/.claude/dev-cycle/jobs/jobs/$JOB_NAME"
BIN_DIR="$HOME/.claude/dev-cycle/jobs/bin"
STATE="$JOB_DIR/state.json"
MANIFEST="$JOB_DIR/job.json"
TEMPLATE="$JOB_DIR/prompt.tmpl.md"
REPORTS="$JOB_DIR/reports"
RUNS="$JOB_DIR/runs.jsonl"
RUN_DATE="$(date +%F)"
RUN_ID="$(date -u +%Y%m%dT%H%M%SZ)"
LOG="$JOB_DIR/logs/run-$RUN_ID.log"
RENDERED="$JOB_DIR/logs/prompt-$RUN_ID.md"
RESULT_JSON="$JOB_DIR/logs/result-$RUN_ID.json"
SUMMARY="$REPORTS/summary-$RUN_DATE.json"
REPORT="$REPORTS/report-$RUN_DATE.md"
MAX_RUNTIME_S=@MAX_RUNTIME_S@
STARTED="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
START_EPOCH="$(date +%s)"
mkdir -p "$REPORTS" "$JOB_DIR/logs"

record_run() {  # $1 status  $2 exit_code  $3 num_turns  $4 note
  local ended dur
  ended="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  dur=$(( $(date +%s) - START_EPOCH ))
  jq -cn --arg id "$RUN_ID" --arg st "$STARTED" --arg en "$ended" \
        --arg status "$1" --arg note "$4" \
        --argjson exit "$2" --argjson dur "$dur" --argjson turns "$3" \
        '{run_id:$id, started:$st, ended:$en, duration_s:$dur,
          status:$status, exit_code:$exit, num_turns:$turns, note:$note}' \
        >> "$RUNS"
}

fail() {  # $1 status  $2 note  — record, notify, exit nonzero
  record_run "$1" 1 0 "$2"
  "$BIN_DIR/notify.sh" "$MANIFEST" "$1" "scheduled-jobs/$JOB_NAME: $2" || true
  exit 1
}

# ---- 1. Preflight: the historical silent-failure mode was an invisible
#         launch problem. Prove the runtime exists before anything else.
command -v claude >/dev/null 2>&1 || fail LAUNCH_FAIL "claude binary not on PATH ($PATH)"
command -v jq     >/dev/null 2>&1 || fail LAUNCH_FAIL "jq not on PATH"
[ -f "$STATE" ]    || fail LAUNCH_FAIL "missing state file $STATE"
[ -f "$TEMPLATE" ] || fail LAUNCH_FAIL "missing template $TEMPLATE"

# ---- 2. Detection (cheap, no Claude). Emits a JSON array of due items to
#         $DUE_FILE. Generated per job at scaffold time; the default body
#         below implements the staleness rule against state.json.
DUE_FILE="$JOB_DIR/logs/due-$RUN_ID.json"
detect_items() {
  jq --argjson ttl @TTL_DAYS@ '
    now as $now
    | [ .items | to_entries[]
        | select(.value.status != "OK"
                 or .value.last_verified == null
                 or ((.value.last_verified + "T00:00:00Z") | fromdate) < ($now - ($ttl*86400)))
        | {name: .key, state: .value} ]' "$STATE" > "$DUE_FILE"
  # @DETECTION_EXTRA@  <- scaffold inserts discovery logic here (e.g. scan a
  # directory, diff against .seen and .ignored, append new items to DUE_FILE)
}
detect_items

DUE_COUNT="$(jq 'length' "$DUE_FILE")"
if [ "$DUE_COUNT" -eq 0 ]; then
  record_run NOTHING_TO_DO 0 0 "no new or stale items; claude not launched"
  exit 0
fi

# ---- 3. Render + lint (never launch an unlinted prompt).
python3 "$BIN_DIR/render_lint.py" \
  --template "$TEMPLATE" --manifest "$MANIFEST" --state "$STATE" \
  --due "$DUE_FILE" --run-date "$RUN_DATE" --report "$REPORT" \
  --summary "$SUMMARY" --out "$RENDERED" \
  || fail LINT_FAIL "prompt failed lint; see $RENDERED.lint"

# ---- 4. Launch headless Claude with a hard timeout (house rule: never
#         silent for minutes; never hung forever).
set +e
claude -p --output-format json \
       --settings "$JOB_DIR/settings.json" \
       --model "$(jq -r '.claude.model' "$MANIFEST")" \
       < "$RENDERED" > "$RESULT_JSON" 2> "$LOG" &
CLAUDE_PID=$!
( sleep "$MAX_RUNTIME_S" && kill "$CLAUDE_PID" 2>/dev/null ) &
KILLER_PID=$!
wait "$CLAUDE_PID"; CLAUDE_EXIT=$?
kill "$KILLER_PID" 2>/dev/null; wait "$KILLER_PID" 2>/dev/null
set -e

NUM_TURNS="$(jq -r '.num_turns // 0' "$RESULT_JSON" 2>/dev/null || echo 0)"
IS_ERROR="$(jq -r 'if .is_error == null then true else .is_error end' "$RESULT_JSON" 2>/dev/null || echo true)"

if [ "$CLAUDE_EXIT" -ne 0 ] || [ "$IS_ERROR" = "true" ]; then
  record_run FAILED "$CLAUDE_EXIT" "$NUM_TURNS" "claude run failed; see $LOG"
  "$BIN_DIR/notify.sh" "$MANIFEST" failure "scheduled-jobs/$JOB_NAME: run FAILED (exit $CLAUDE_EXIT)" || true
  exit 1
fi

# ---- 5. Verify the output contract was honored.
[ -f "$SUMMARY" ] || fail FAILED "run exited 0 but summary $SUMMARY missing"
[ -f "$REPORT" ]  || fail FAILED "run exited 0 but report $REPORT missing"
SUMMARY_STATUS="$(jq -r '.status' "$SUMMARY")"
MATERIAL="$(jq '.material_changes | length' "$SUMMARY")"

# ---- 6. Report lifecycle: dated history + diff vs previous + latest symlink.
PREV="$(ls -1 "$REPORTS"/report-*.md 2>/dev/null | grep -v "$REPORT" | sort | tail -1 || true)"
if [ -n "$PREV" ]; then
  diff -u "$PREV" "$REPORT" > "$REPORTS/diff-$RUN_DATE.txt" || true
fi
ln -sfn "$REPORT" "$REPORTS/latest.md"

record_run "$SUMMARY_STATUS" 0 "$NUM_TURNS" "$MATERIAL material change(s)"

# ---- 7. Deliver: notify only when there is something to say.
if [ "$MATERIAL" -gt 0 ] || [ "$SUMMARY_STATUS" != "SUCCESS" ]; then
  HEADLINE="$(jq -r '[.material_changes[] | "\(.item): \(.from)->\(.to)"] | join("; ")' "$SUMMARY")"
  "$BIN_DIR/notify.sh" "$MANIFEST" material_change \
    "scheduled-jobs/$JOB_NAME [$SUMMARY_STATUS]: ${HEADLINE:-see $REPORT}" || true
fi
exit 0
